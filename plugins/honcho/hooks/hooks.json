{
  "description": "Honcho memory hooks for Claude Code sessions",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["run", "${CLAUDE_PLUGIN_ROOT}/hooks/ensure-deps.ts"],
            "timeout": 60
          },
          {
            "type": "command",
            "command": "bun",
            "args": ["run", "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.ts"],
            "timeout": 30,
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash|Task",
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["run", "${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use.ts"],
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["run", "${CLAUDE_PLUGIN_ROOT}/hooks/user-prompt.ts"],
            "timeout": 7
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["run", "${CLAUDE_PLUGIN_ROOT}/hooks/pre-compact.ts"],
            "timeout": 20
          }
        ]
      },
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["run", "${CLAUDE_PLUGIN_ROOT}/hooks/pre-compact.ts"],
            "timeout": 20
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["run", "${CLAUDE_PLUGIN_ROOT}/hooks/stop.ts"],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
